{
	"name": "@digicatalyst/dep-diff-mcp",
	"mcpName": "io.github.DigiCatalyst-Systems/dep-diff-mcp",
	"version": "0.1.4",
	"description": "MCP server that translates a lockfile diff into a human-readable upgrade plan.",
	"type": "module",
	"main": "dist/server.js",
	"module": "dist/index.js",
	"bin": {
		"dep-diff-mcp": "dist/server.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
		"prepublishOnly": "npm run build",
		"dev": "tsx src/server.ts",
		"start": "node dist/server.js",
		"test": "node --import tsx --test tests/*.test.ts",
		"inspect": "npx @modelcontextprotocol/inspector node dist/server.js",
		"worker:dev": "wrangler dev",
		"worker:deploy": "wrangler deploy"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"dependencies",
		"changelog",
		"cve",
		"dependabot",
		"cursor"
	],
	"author": "Kaustubh Ghodke",
	"organization": "Digicatalyst Systems",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DigiCatalyst-Systems/dep-diff-mcp.git"
	},
	"homepage": "https://github.com/DigiCatalyst-Systems/dep-diff-mcp#readme",
	"bugs": {
		"url": "https://github.com/DigiCatalyst-Systems/dep-diff-mcp/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"lru-cache": "^11.3.5",
		"p-limit": "^7.3.0",
		"semver": "^7.7.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260423.1",
		"@types/node": "^25.6.0",
		"@types/semver": "^7.7.1",
		"esbuild": "^0.28.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"wrangler": "^4.84.1"
	}
}

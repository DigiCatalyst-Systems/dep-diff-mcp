{
	"$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
	"name": "dep-diff-mcp",
	"main": "src/worker.ts",
	"compatibility_date": "2026-04-01",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"analytics_engine_datasets": [
		{
			"binding": "ANALYTICS",
			"dataset": "dep_diff_mcp_usage"
		}
	]
}
